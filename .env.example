NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/finance_dashboard
JWT_SECRET=replace-with-at-least-32-characters-secret
JWT_EXPIRES_IN=12h
JWT_ISSUER=finance-dashboard
JWT_AUDIENCE=finance-dashboard-clients
BCRYPT_SALT_ROUNDS=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_REGISTER_MAX_ATTEMPTS=10
JSON_BODY_LIMIT=100kb
TRUST_PROXY=false
ERROR_INCLUDE_STACK=false
SEED_ADMIN_NAME=System Admin
SEED_ADMIN_EMAIL=replace-admin-email@example.com
SEED_ADMIN_PASSWORD=ReplaceWithStrongPassword@123